# ===========================================
# Pool Server v2 — Configuration
# ===========================================
# Copy: cp .env.example .env && nano .env

# Data
DATA_DIR=/data
KEYDB_URL=redis://127.0.0.1:6379/0
# With password: redis://:YOUR_PASSWORD@127.0.0.1:6379/0

# Security
SECRET_KEY=
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(64))"

# CORS — comma-separated allowed origins
CORS_ORIGINS=https://training.bbdata.net,https://bbdata.net

# Trainer authentication (REQUIRED)
TRAINER_AUTH_TOKEN=
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# Telegram (optional, can be set in admin Settings)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_STATS_INTERVAL=15

# Server
HOST=0.0.0.0
PORT=8421
DEBUG=false

# Timeouts (seconds)
MACHINE_ALIVE_TTL=60
ACTIVE_X_TTL=300
