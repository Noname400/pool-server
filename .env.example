# ===========================================
# Pool Server — All-in-One Docker Configuration
# ===========================================
# Copy this to .env and fill in values:
#   cp .env.example .env && nano .env

# PostgreSQL password (REQUIRED for docker-compose)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=

# JWT signing key (auto-generated if empty, but set explicitly for stable sessions)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Admin API key (used on first run to create admin user)
# If empty, a random key is generated and printed to stdout on first run
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# CORS — comma-separated allowed origins
CORS_ORIGINS=https://training.bbdata.net,https://bbdata.net

# Trainer v2 authentication
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
TRAINER_AUTH_TOKEN=
TRAINER_ADMIN_TOKEN=

# Telegram notifications (optional, can be set in admin UI)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
